FROM dunglas/frankenphp:php8.4-alpine

ARG UID=1000
ARG GID=1000

WORKDIR /app

# Install PHP extensions
RUN install-php-extensions \
    pcntl \
    zip \
    bcmath \
    intl \
    imagick \
    pdo_mysql \
    redis \
    gd \
    opcache

# Install Node.js, npm, git, and netcat (for wait-for-db)
RUN apk add --no-cache nodejs npm git netcat-openbsd

# Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Set entrypoint
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Ensure storage and bootstrap/cache exist and have correct permissions
RUN mkdir -p storage bootstrap/cache && \
    chown -R www-data:www-data /app && \
    chmod -R 775 storage bootstrap/cache

# Set default environment variables for Octane
ENV OCTANE_SERVER=frankenphp
ENV WATCH_MODE=true

# Use root to allow entrypoint to fix permissions on mounted volumes
USER root

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command for development
CMD ["--watch", "--workers=1"]
